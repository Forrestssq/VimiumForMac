<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  No sandbox: VimHint needs CGEventTap (global key interception) and
	  AXUIElement access across all processes — both are incompatible with
	  the app sandbox. Distribution is direct (not Mac App Store).
	-->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
